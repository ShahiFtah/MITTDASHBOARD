{
  "name": "mitt-dashboard",
  "version": "1.0.4",
  "description": "Personlig dashboard med Spotify",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "open": "^8.4.2"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.dittdashboard.app",
    "productName": "Mitt Dashboard",
    "publish": {
      "provider": "github",
      "owner": "ShahiFtah",
      "repo": "MITTDASHBOARD",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
